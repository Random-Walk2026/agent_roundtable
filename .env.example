# Mock mode needs no keys:
# python main.py --topic "AI 会不会取代程序员" --council experts --rounds 2 --mock

# Gemini API config. Multiple keys are tried in numeric order.
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_MAX_OUTPUT_TOKENS=4096

# OpenAI placeholder config.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT=60

# OpenRouter placeholder config.
OPENROUTER_API_KEY_1=
OPENROUTER_API_KEY_2=
OPENROUTER_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free,poolside/laguna-m.1:free,nvidia/nemotron-3-super-120b-a12b:free,openai/gpt-oss-120b:free
OPENROUTER_TIMEOUT=60

# DeepSeek uses an OpenAI-compatible API.
# Official chat models: deepseek-v4-flash, deepseek-v4-pro.
# Legacy names deepseek-chat and deepseek-reasoner are kept for compatibility
# and are scheduled for deprecation by DeepSeek on 2026-07-24 23:59 Beijing time.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_TIMEOUT=60

# Local subscription CLIs used by provider chains such as claude:sonnet@high
# and codex:gpt-5.5@medium. Leave binary names empty to use PATH defaults.
CLAUDE_CLI_BIN=claude
CODEX_CLI_BIN=codex
CLI_SUBPROCESS_TIMEOUT=600

# CLIProxyAPI HTTP service for antigravity/grok/copilot provider-chain entries.
CLI_PROXY_BASE_URL=http://127.0.0.1:8317
CLI_PROXY_API_KEY=local
CLI_PROXY_TIMEOUT=600
